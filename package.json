{
    "name": "swarm-cli",
    "version": "1.0.0",
    "description": "The reference CLI for the Swarm framework — a reconcile-only harness for spec-driven agent work.",
    "keywords": [
        "swarm",
        "spec-driven",
        "agents",
        "cli",
        "reconcile",
        "worktree"
    ],
    "homepage": "https://github.com/jcosta33/swarm-cli#readme",
    "bugs": {
        "url": "https://github.com/jcosta33/swarm-cli/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jcosta33/swarm-cli.git"
    },
    "license": "ISC",
    "author": "José Costa",
    "type": "module",
    "bin": {
        "swarm": "./bin/swarm.js"
    },
    "files": [
        "bin",
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18.18.0"
    },
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --target=node18 --outfile=dist/index.js",
        "prepack": "pnpm run build",
        "test": "vitest",
        "test:run": "vitest run",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"**/*.{ts,js,mjs,cjs,json,md}\"",
        "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ \"src/**/*.ts\"",
        "lint:fix": "eslint --cache --cache-location node_modules/.cache/eslint/ --fix \"src/**/*.ts\"",
        "deps:validate": "depcruise src --config .dependency-cruiser.cjs"
    },
    "dependencies": {
        "@clack/prompts": "^1.2.0",
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.5",
        "dependency-cruiser": "^17.3.10",
        "esbuild": "^0.28.1",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "knip": "^6.5.0",
        "prettier": "^3.5.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2",
        "vitest": "^4.1.4"
    }
}
