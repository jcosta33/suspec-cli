{
    "name": "suspec-cli",
    "version": "1.0.0",
    "packageManager": "pnpm@10.32.1",
    "description": "The reference checker for the Suspec methodology — a path-agnostic, deterministic checker for Suspec artifacts.",
    "keywords": [
        "suspec",
        "spec-driven",
        "agents",
        "cli",
        "check",
        "lint"
    ],
    "homepage": "https://github.com/jcosta33/suspec-cli#readme",
    "bugs": {
        "url": "https://github.com/jcosta33/suspec-cli/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jcosta33/suspec-cli.git"
    },
    "license": "MIT",
    "author": "José Costa",
    "type": "module",
    "bin": {
        "suspec": "./bin/suspec.js"
    },
    "files": [
        "bin",
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=22.6.0"
    },
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --target=node18 --outfile=dist/index.js",
        "prepack": "pnpm run build",
        "test": "vitest",
        "test:run": "vitest run",
        "coverage": "vitest run --coverage",
        "gate": "pnpm typecheck && pnpm lint && pnpm deps:validate && pnpm coverage && pnpm build",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"**/*.{ts,js,mjs,cjs,json,md}\"",
        "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ \"src/**/*.ts\"",
        "lint:fix": "eslint --cache --cache-location node_modules/.cache/eslint/ --fix \"src/**/*.ts\"",
        "deps:validate": "depcruise src bin --config .dependency-cruiser.cjs",
        "format:check": "prettier --check \"**/*.{ts,js,mjs,cjs,json,md}\""
    },
    "dependencies": {
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.5",
        "dependency-cruiser": "^17.3.10",
        "esbuild": "^0.28.1",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "knip": "^6.5.0",
        "prettier": "^3.5.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2",
        "vitest": "^4.1.4"
    }
}
